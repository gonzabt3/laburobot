# Copy this file to .env and fill in values
# Never commit your actual .env to source control

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ── WhatsApp Cloud API ─────────────────────────────────────────
WHATSAPP_TOKEN=your_meta_cloud_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=a_secret_you_choose
WHATSAPP_APP_SECRET=your_meta_app_secret

# ── Admin panel ────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── AI / LLM (optional — stub works without keys) ─────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Location geocoding (optional) ─────────────────────────────
# GEOCODE_API_KEY=your_google_maps_api_key

# ── Rails ─────────────────────────────────────────────────────
RAILS_MASTER_KEY=your_master_key_for_production
